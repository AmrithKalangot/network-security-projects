# ============================================================================
# SURICATA THRESHOLD & SUPPRESSION CONFIGURATION
# ============================================================================
# This file is used to globally manage alert fatigue without modifying 
# the underlying signature files downloaded from Emerging Threats (ET).

# Format: threshold gen_id <gid>, sig_id <sid>, type <limit|threshold|both>, track <by_src|by_dst>, count <N>, seconds <T>

# Throttle NMAP OS Detection Probes (SID 2000499) to 1 alert per 60 seconds per source IP
threshold gen_id 1, sig_id 2000499, type limit, track by_src, count 1, seconds 60

# Throttle standard ICMP Echo Requests (Ping) to prevent pipeline flooding during basic testing
threshold gen_id 1, sig_id 2000000, type limit, track by_src, count 1, seconds 60

# (Example) Completely suppress a noisy false-positive signature internally
# suppress gen_id 1, sig_id 2010935, track by_src, ip 192.168.10.0/24
